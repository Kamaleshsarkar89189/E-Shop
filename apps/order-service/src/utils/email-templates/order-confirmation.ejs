<!DOCTYPE html>
<html>

<head>
    <title>Eshop Order Confirmation</title>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style type="text/css">
        /* Base */
        body {
            margin: 0;
            padding: 0;
            min-width: 100%;
            font-family: Arial, sans-serif;
            font-size: 16px;
            line-height: 1.5;
            background-color: #fafafa;
            color: #222222;
        }

        a {
            color: #0070f3;
            text-decoration: none;
        }

        h1 {
            font-size: 24px;
            font-weight: 700;
            margin: 0 0 15px;
            text-align: center;
        }

        h2 {
            font-size: 20px;
            margin: 20px 0 10px;
        }

        p {
            margin: 0 0 16px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 16px;
        }

        table th,
        table td {
            padding: 8px 12px;
            border: 1px solid #ddd;
            text-align: left;
        }

        table th {
            background-color: #f6f6f6;
        }

        /* Layout */
        .email-wrapper {
            max-width: 600px;
            margin: 0 auto;
        }

        .email-header {
            background-color: #0070f3;
            padding: 24px;
            color: #ffffff;
        }

        .email-body {
            padding: 24px;
            background-color: #ffffff;
        }

        .email-footer {
            background-color: #f6f6f6;
            padding: 24px;
            text-align: center;
        }

        /* Buttons */
        .button {
            display: inline-block;
            background-color: #0070f3;
            color: #ffffff;
            font-size: 16px;
            font-weight: 700;
            text-align: center;
            text-decoration: none;
            padding: 12px 24px;
            border-radius: 4px;
            margin-top: 20px;
        }
    </style>
</head>

<body>
    <div class="email-wrapper">
        <div class="email-header">
            <h1>Order Confirmation</h1>
        </div>
        <div class="email-body">
            <p>Hello <%= name %>,</p>
            <p>
                Thank you for shopping with <strong>Eshop</strong>! Your order <strong>#<%= orderId %></strong> has been
                confirmed.
            </p>

            <h2>Order Summary</h2>
            <table>
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Price</th>
                    </tr>
                </thead>
                <tbody>
                    <% orderItems.forEach(function(item) { %>
                        <tr>
                            <td>
                                <%= item.name %>
                            </td>
                            <td>
                                <%= item.quantity %>
                            </td>
                            <td>₹<%= item.price %>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>

            <p><strong>Total:</strong> ₹<%= orderTotal %>
            </p>

            <p>
                We’ll notify you once your items are shipped. You can track your order using the button below.
            </p>

            <a href="<%= trackingUrl %>" class="button">Track Order</a>
        </div>

        <div class="email-footer">
            <p>
                If you have any questions, contact us at
                <a href="mailto:kamaleshsarkar003@gmail.com">kamaleshsarkar003@gmail.com</a>
            </p>
        </div>
    </div>
</body>

</html>